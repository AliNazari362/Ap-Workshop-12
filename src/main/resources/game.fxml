<AnchorPane minHeight="720" minWidth="1280"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.GameController">

    <style>
        -fx-background-color: radial-gradient(center 50% 50%, radius 70%, #2a2a2a, #0a0a0a);
    </style>

    <Text fx:id="timerText" layoutX="540" layoutY="100.0" textAlignment="CENTER" wrappingWidth="200.0">
        <fill>
            <LinearGradient endX="1.0" endY="1.0">
                <stops>
                    <Stop offset="0.0">
                        <color>
                            <Color red="0.9" green="0.7" blue="0.1"/>
                        </color>
                    </Stop>
                    <Stop offset="0.5">
                        <color>
                            <Color red="0.8" green="0.8" blue="0.8"/>
                        </color>
                    </Stop>
                    <Stop offset="1.0">
                        <color>
                            <Color red="0.9" green="0.7" blue="0.1"/>
                        </color>
                    </Stop>
                </stops>
            </LinearGradient>
        </fill>
        <font>
            <Font name="System Bold" size="60.0"/>
        </font>
        <effect>
            <DropShadow offsetX="0" offsetY="4" color="#ffd70044"/>
            <Glow level="0.3"/>
        </effect>
    </Text>

    <Text layoutX="540" layoutY="130.0" text="⏱ Time Remaining" textAlignment="CENTER" wrappingWidth="200.0"
          fill="#888888">
        <font>
            <Font size="16.0"/>
        </font>
    </Text>

    <Text fx:id="playerTag" layoutX="490" layoutY="160.0" textAlignment="CENTER" wrappingWidth="300.0"
          fill="#c0c0c0">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Text>

