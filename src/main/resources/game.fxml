<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane minHeight="720" minWidth="1280"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.GameController">

    <style>
        -fx-background-color: radial-gradient(center 50% 50%, radius 70%, #2a2a2a, #0a0a0a);
    </style>

    <Text layoutX="540" layoutY="100.0" text="00:30" textAlignment="CENTER" wrappingWidth="200.0">
        <fill>
            <LinearGradient endX="1.0" endY="1.0">
                <stops>
                    <Stop offset="0.0">
                        <color>
                            <Color red="0.9" green="0.7" blue="0.1" />
                        </color>
                    </Stop>
                    <Stop offset="0.5">
                        <color>
                            <Color red="0.8" green="0.8" blue="0.8" />
                        </color>
                    </Stop>
                    <Stop offset="1.0">
                        <color>
                            <Color red="0.9" green="0.7" blue="0.1" />
                        </color>
                    </Stop>
                </stops>
            </LinearGradient>
        </fill>
        <font>
            <Font name="System Bold" size="60.0" />
        </font>
        <effect>
            <DropShadow offsetX="0" offsetY="4" color="#ffd70044"/>
            <Glow level="0.3"/>
        </effect>
    </Text>

    <Text layoutX="540" layoutY="130.0" text="⏱ Time Remaining" textAlignment="CENTER" wrappingWidth="200.0" fill="#888888">
        <font>
            <Font size="16.0" />
        </font>
    </Text>

    <Text layoutX="490" layoutY="160.0" text="Player's Turn: X" textAlignment="CENTER" wrappingWidth="300.0"
          fill="#c0c0c0">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Text>

    <GridPane layoutX="460" layoutY="200.0" hgap="8.0" vgap="8.0">
        <!-- ردیف اول -->
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" arcWidth="15.0" arcHeight="15.0" />
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" GridPane.columnIndex="1" arcWidth="15.0" arcHeight="15.0" />
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" GridPane.columnIndex="2" arcWidth="15.0" arcHeight="15.0" />

        <!-- ردیف دوم -->
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" GridPane.rowIndex="1" arcWidth="15.0" arcHeight="15.0" />
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" GridPane.rowIndex="1" GridPane.columnIndex="1" arcWidth="15.0" arcHeight="15.0" />
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" GridPane.rowIndex="1" GridPane.columnIndex="2" arcWidth="15.0" arcHeight="15.0" />

        <!-- ردیف سوم -->
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" GridPane.rowIndex="2" arcWidth="15.0" arcHeight="15.0" />
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" GridPane.rowIndex="2" GridPane.columnIndex="1" arcWidth="15.0" arcHeight="15.0" />
        <Rectangle width="120.0" height="120.0" fill="#1a1a1a" stroke="#ffd700" strokeWidth="2.0" GridPane.rowIndex="2" GridPane.columnIndex="2" arcWidth="15.0" arcHeight="15.0" />
    </GridPane>

    <Button layoutX="30.0" layoutY="30.0" prefHeight="50.0" prefWidth="150.0"
            style="-fx-border-radius: 25; -fx-background-radius: 25;
                    -fx-border-color: #ffd700;
                    -fx-border-width: 2;
                    -fx-background-color: transparent;
                    -fx-text-fill: #ffd700;
                    -fx-font-weight: bold;
                    -fx-cursor: hand;
                    -fx-font-size: 18"
           fx:id="goToHome" text="Back" textFill="#ffd700">
    </Button>

    <Button layoutX="1100.0" layoutY="30.0" prefHeight="50.0" prefWidth="150.0"
            style="-fx-border-radius: 25; -fx-background-radius: 25;
                    -fx-border-color: #ffd700;
                    -fx-border-width: 2;
                    -fx-background-color: transparent;
                    -fx-text-fill: #ffd700;
                    -fx-font-weight: bold;
                    -fx-cursor: hand;
                    -fx-font-size: 18;"
            text="Sound On" textFill="#ffd700">
    </Button>

    <Button layoutX="590.0" layoutY="650.0" prefHeight="50.0" prefWidth="100.0"
            style="-fx-border-radius: 25; -fx-background-radius: 25;
                    -fx-border-color: #666666;
                    -fx-border-width: 2;
                    -fx-background-color: transparent;
                    -fx-text-fill: #888888;
                    -fx-font-weight: bold;
                    -fx-cursor: hand;
                    -fx-font-size: 15"
            text="Reset" textFill="#888888">
    </Button>

</AnchorPane>