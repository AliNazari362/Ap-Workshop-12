<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>

<AnchorPane minHeight="720" minWidth="1280"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.LoginController">

    <style>
        -fx-background-color: radial-gradient(center 50% 50%, radius 80%, #2a2a2a, #0a0a0a);
    </style>

    <Text layoutX="540" layoutY="150.0" text="Login">
        <fill>
            <LinearGradient endX="1.0" endY="1.0">
                <stops>
                    <Stop offset="0.0">
                        <color>
                            <Color red="0.9" green="0.7" blue="0.1" />
                        </color>
                    </Stop>
                    <Stop offset="0.5">
                        <color>
                            <Color red="0.8" green="0.8" blue="0.8" />
                        </color>
                    </Stop>
                    <Stop offset="1.0">
                        <color>
                            <Color red="0.9" green="0.7" blue="0.1" />
                        </color>
                    </Stop>
                </stops>
            </LinearGradient>
        </fill>
        <font>
            <Font name="System Bold" size="60.0" />
        </font>
        <effect>
            <DropShadow offsetX="0" offsetY="4" color="#00000088"/>
        </effect>
    </Text>

    <Text fill="#c0c0c0" layoutX="490" layoutY="250.0" textAlignment="CENTER" wrappingWidth="300.0">
        <font>
            <Font size="28.0"/>
        </font>
        Enter Your Name
    </Text>

    <TextField fx:id="nameInput" layoutX="440" layoutY="280.0" prefHeight="50.0" prefWidth="400.0"
               style="-fx-background-color: #1a1a1a;
                      -fx-text-fill: #ffd700;
                      -fx-border-color: #ffd700;
                      -fx-border-width: 2;
                      -fx-border-radius: 10;
                      -fx-background-radius: 10;
                      -fx-font-size: 20px;
                      -fx-prompt-text-fill: #666666;"
               promptText="Enter your name...">
        <font>
            <Font size="20.0" />
        </font>
    </TextField>

    <Button fx:id="goToStart" layoutX="340" layoutY="400.0" prefHeight="60.0" prefWidth="180.0"
            style="-fx-border-radius: 30; -fx-background-radius: 30;
                    -fx-border-color: #666666;
                    -fx-border-width: 2;
                    -fx-background-color: linear-gradient(to bottom, #1a1a1a, #0d0d0d);
                    -fx-text-fill: #999999;
                    -fx-font-weight: bold;
                    -fx-cursor: hand;
                    -fx-effect: dropshadow(gaussian, rgba(255,255,255,0.1), 10, 0.2, 0, 0);"
            text="Back" textFill="#999999">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Button>

    <Button fx:id="goToGame" layoutX="760" layoutY="400.0" prefHeight="60.0" prefWidth="180.0"
            style="-fx-border-radius: 30; -fx-background-radius: 30;
                    -fx-border-color: #ffd700;
                    -fx-border-width: 2;
                    -fx-background-color: linear-gradient(to bottom, #1a1a1a, #0d0d0d);
                    -fx-text-fill: #ffd700;
                    -fx-font-weight: bold;
                    -fx-cursor: hand;
                    -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.3), 15, 0.3, 0, 0);"
            text="Start Game" textFill="#ffd700">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Button>

</AnchorPane>