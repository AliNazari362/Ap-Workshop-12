<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.Glow?>

<AnchorPane minHeight="720" minWidth="1280"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.StartController">

    <style>
        -fx-background-color: radial-gradient(center 50% 50%, radius 70%, #2a2a2a, #0a0a0a);
    </style>

    <Text layoutX="390" layoutY="300.0" text="TicToc Game">
        <fill>
            <LinearGradient endX="1.0" endY="1.0">
                <stops>
                    <Stop offset="0.0">
                        <color>
                            <Color red="0.9" green="0.7" blue="0.1"/>
                        </color>
                    </Stop>
                    <Stop offset="0.5">
                        <color>
                            <Color red="0.8" green="0.8" blue="0.8"/>
                        </color>
                    </Stop>
                    <Stop offset="1.0">
                        <color>
                            <Color red="0.9" green="0.7" blue="0.1"/>
                        </color>
                    </Stop>
                </stops>
            </LinearGradient>
        </fill>
        <font>
            <Font name="System Bold" size="80.0"/>
        </font>
        <effect>
            <DropShadow offsetX="0" offsetY="4" color="#ffd70044"/>
            <Glow level="0.2"/>
        </effect>
    </Text>

    <Text fill="#888888" layoutX="490" layoutY="360.0" textAlignment="CENTER" wrappingWidth="300.0">
        <font>
            <Font size="20.0"/>
        </font>
        <effect>
            <Glow level="0.1"/>
        </effect>
        Welcome to the Game
    </Text>

    <Button layoutX="540" layoutY="450.0" prefHeight="60.0" prefWidth="200.0"
            style="-fx-border-radius: 30; -fx-background-radius: 30;
                    -fx-border-color: #ffd700;
                    -fx-border-width: 2;
                    -fx-background-color: linear-gradient(to bottom, #1a1a1a, #0d0d0d);
                    -fx-text-fill: #ffd700;
                    -fx-font-weight: bold;
                    -fx-font-size: 24;
                    -fx-cursor: hand;
                    -fx-effect: dropshadow(gaussian, rgba(255,215,0,0.3), 15, 0.3, 0, 0);"
            fx:id="goToLogin" text="Login" textFill="#ffd700">
    </Button>

    <Button layoutX="540" layoutY="540.0" prefHeight="60.0" prefWidth="200.0"
            style="-fx-border-radius: 30; -fx-background-radius: 30;
                    -fx-border-color: #ff3333;
                    -fx-border-width: 2;
                    -fx-background-color: linear-gradient(to bottom, #1a1a1a, #0d0d0d);
                    -fx-text-fill: #ff3333;
                    -fx-font-weight: bold;
                    -fx-cursor: hand;
                    -fx-font-size: 24;
                    -fx-effect: dropshadow(gaussian, rgba(255,51,51,0.2), 15, 0.3, 0, 0);"
            fx:id="exitBtn" text="Exit" textFill="#ff3333">
    </Button>

</AnchorPane>